# CREA DDF Credentials
# The server reads CREA_DDF_USERNAME / CREA_DDF_PASSWORD (not DDF_USERNAME).
CREA_DDF_USERNAME=your_ddf_username
CREA_DDF_PASSWORD=your_ddf_password

# Database
DATABASE_URL=postgresql://user:password@host:5432/realist

# Server
PORT=3000
NODE_ENV=development
# REQUIRED: used to sign session cookies. Generate a strong random string.
SESSION_SECRET=change_me_to_a_long_random_string

# Auth (Google OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://realist.ca/api/auth/google/callback

# Anthropic (REQUIRED for AI features: multiplex underwriter narratives + Ask Realist)
# Without it, AI narratives fall back to templates and /api/ask returns 503
# (the Ask Realist panel hides itself). Verify after deploy: GET /api/ask/status
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Mapbox (for frontend map - REQUIRED for map view)
# Get free token at https://mapbox.com
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# Stripe (REQUIRED for paid features: Ask Realist premium, events, etc.)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_PRICE_ID=
STRIPE_STARTER_PRICE_ID=
STRIPE_EXPERT_PRICE_ID=
STRIPE_MEETUP_PRICE_ID=
STRIPE_ASK_REALIST_PRICE_ID=

# GoHighLevel (GHL) lead plumbing
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_WEBHOOK_URL=

# Replit / deployment
REPLIT_DOMAINS=realist.ca,www.realist.ca
REPLIT_DEV_DOMAIN=realist.replit.dev
REPLIT_CONNECTORS_HOSTNAME=

# Public origin used in transactional emails
PUBLIC_SITE_URL=https://realist.ca
