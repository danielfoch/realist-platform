# CREA DDF Credentials
DDF_USERNAME=your_ddf_username
DDF_PASSWORD=your_ddf_password
DDF_PROVIDER=your_idx_provider_name

# Database
DATABASE_URL=postgresql://user:password@host:5432/realist

# Rent API (from realist.ca scraper)
RENT_API_URL=https://realist.ca/api/rents
RENT_API_KEY=your_rent_api_key

# Server
PORT=3000
NODE_ENV=development

# Anthropic (REQUIRED for AI features: multiplex underwriter narratives + Ask Realist)
# Without it, AI narratives fall back to templates and /api/ask returns 503
# (the Ask Realist panel hides itself). Verify after deploy: GET /api/ask/status
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Mapbox (for frontend map - REQUIRED for map view)
# Get free token at https://mapbox.com
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# Sync Schedule (cron format)
SYNC_SCHEDULE=0 2 * * * # Daily at 2 AM

# API Rate Limiting
API_RATE_LIMIT=100
API_RATE_WINDOW=15m

# Live Deal Room (Mondays 11:30am ET on Google Meet)
# Recurring Meet link used when auto-scheduling weekly sessions
DEAL_ROOM_MEET_URL=https://meet.google.com/your-recurring-link
# Service-account JSON (raw or base64) with access to the shared "Meet Recordings"
# Drive folder — share the folder with the service account's email
DEAL_ROOM_GOOGLE_SA_JSON=
DEAL_ROOM_DRIVE_FOLDER_ID=
# When "true", the sweep emails the replay to registrants as soon as ingest completes
DEAL_ROOM_AUTO_SEND_REPLAY=true
# CRM owner for platform-captured contacts (falls back to the oldest admin user)
CRM_OWNER_USER_ID=
# Public origin used in transactional emails
PUBLIC_SITE_URL=https://realist.ca
