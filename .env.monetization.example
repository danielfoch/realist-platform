# Monetization Environment Variables

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d

# Stripe Integration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PREMIUM=price_1234567890 # Monthly $29
STRIPE_PRICE_ENTERPRISE=price_9876543210 # Custom pricing

# GoHighLevel CRM Integration
GHL_API_KEY=your_ghl_api_key
GHL_LOCATION_ID=your_location_id
GHL_PIPELINE_ID=your_pipeline_id_for_partnerships
GHL_STAGE_ID=your_stage_id_for_new_leads
GHL_DEFAULT_USER_ID=user_id_for_assignment

# Admin API Key (for lead management endpoints)
ADMIN_API_KEY=your-admin-api-key

# Feature Flags (optional)
ENABLE_PREMIUM_FEATURES=true
ENABLE_LEAD_CAPTURE=true