{
  "name": "realist-idx-integration",
  "version": "1.0.0",
  "description": "CREA DDF IDX integration for Realist.ca",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "sync": "tsx src/sync-listings.ts",
    "sync:full": "tsx src/sync-listings.ts --full",
    "test:ddf": "tsx src/test-ddf-connection.ts",
    "migrate": "tsx src/scripts/migrate.ts",
    "seed": "tsx src/scripts/seed.ts",
    "test": "jest --runInBand --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "check": "npm run type-check && npm run lint && npm run test"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "body-parser": "^1.20.3",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^7.1.0",
    "drizzle-orm": "^0.29.3",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8",
    "xml2js": "^0.6.2",
    "cors": "^2.8.5",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/jest": "^29.5.14",
    "@types/morgan": "^1.9.9",
    "@types/supertest": "^6.0.3",
    "@types/node": "^20.11.16",
    "@types/express": "^4.17.21",
    "@types/pg": "^8.11.0",
    "@types/xml2js": "^0.4.14",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "jest": "^29.7.0",
    "nock": "^14.0.10",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
